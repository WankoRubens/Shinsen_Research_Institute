# OpenRouter API key for LLM translation
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Anthropic API key (optional — used by some LLM scripts directly)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Supabase (frontend short-URL share). Publishable key is browser-safe under RLS.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Comma-separated route names bundled into the app. Omit locally to include all.
VITE_PUBLISHED_PAGES=lineup,profiles,groups,shares,proposals,battleSim,mockBattle,aiLineup,heroDb,settings

# When true, only the five public pages above are available by default. Other
# pages require the signed-in user's UUID in public.feature_access_users.
VITE_PAGE_ACCESS_CONTROL=true
